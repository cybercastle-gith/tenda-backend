# Ambiente e Porta
NODE_ENV=development
PORT=3000

# JWT (autenticação com access token e refresh token)
JWT_SECRET=your_jwt_secret_min_32_chars_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Banco de Dados (Configuração padrão para o Docker)
DB_HOST=db-solar
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=tenda_back

ADMIN_PASSWORD = senha_forte

# E-mail (Configurações de SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app
EMAIL_FROM="Tenda Energia <seuemail@gmail.com>"